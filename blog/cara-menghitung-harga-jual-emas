    <script>
        function hitungEmas() {
            const kadar = parseFloat(document.getElementById('kadar').value);
            const berat = parseFloat(document.getElementById('berat').value);
            const harga24k = parseFloat(document.getElementById('harga24k').value);

            if (!berat || berat <= 0 || !harga24k || harga24k <= 0) {
                alert('Mohon isi berat dan harga dengan benar.');
                return;
            }

            const estimasi = (kadar / 24) * berat * harga24k;
            const formatted = new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(estimasi);
            const persen = ((kadar / 24) * 100).toFixed(1);

            document.getElementById('hasilAngka').textContent = formatted;
            document.getElementById('hasilDetail').textContent = `Kadar ${kadar}K (${persen}%) × ${berat}g × Rp${harga24k.toLocaleString('id-ID')}/gram`;
            document.getElementById('hasil').classList.remove('hidden');
        }
    </script>

